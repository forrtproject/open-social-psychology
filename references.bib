@article{franzen_power_2023,
	title = {The power of social influence: {A} replication and extension of the {Asch} experiment},
	volume = {18},
	issn = {1932-6203},
	shorttitle = {The power of social influence},
	url = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0294325},
	doi = {10.1371/journal.pone.0294325},
	abstract = {In this paper, we pursue four goals: First, we replicate the original Asch experiment with five confederates and one naïve subject in each group (N = 210). Second, in a randomized trial we incentivize the decisions in the line experiment and demonstrate that monetary incentives lower the error rate, but that social influence is still at work. Third, we confront subjects with different political statements and show that the power of social influence can be generalized to matters of political opinion. Finally, we investigate whether intelligence, self-esteem, the need for social approval, and the Big Five are related to the susceptibility to provide conforming answers. We find an error rate of 33\% for the standard length-of-line experiment which replicates the original findings by Asch (1951, 1955, 1956). Furthermore, in the incentivized condition the error rate decreases to 25\%. For political opinions we find a conformity rate of 38\%. However, besides openness, none of the investigated personality traits are convincingly related to the susceptibility of group pressure.},
	language = {en},
	number = {11},
	urldate = {2026-05-19},
	journal = {PLOS ONE},
	publisher = {Public Library of Science},
	author = {Franzen, Axel and Mader, Sebastian},
	month = nov,
	year = {2023},
	keywords = {Experimental economics, Experimental psychology, In FLoRA, Intelligence, Is Replication, Measurement, Personality traits, Questionnaires, Replication: Successful, Schools, Social influence},
	pages = {e0294325},
	file = {Full Text PDF:/Users/rima-mariarahal/Zotero/storage/HSQ847VL/Franzen and Mader - 2023 - The power of social influence A replication and extension of the Asch experiment.pdf:application/pdf},
}

