@article{paluck_prejudice_2021,
	title = {Prejudice {Reduction}: {Progress} and {Challenges}},
	volume = {72},
	issn = {0066-4308, 1545-2085},
	shorttitle = {Prejudice {Reduction}},
	url = {https://www.annualreviews.org/content/journals/10.1146/annurev-psych-071620-030619},
	doi = {10.1146/annurev-psych-071620-030619},
	abstract = {The past decade has seen rapid growth in research that evaluates methods for reducing prejudice. This essay reviews 418 experiments reported in 309 manuscripts from 2007 to 2019 to assess which approaches work best and why. Our quantitative assessment uses meta-analysis to estimate average effects. Our qualitative assessment calls attention to landmark studies that are noteworthy for sustained interventions, imaginative measurement, and transparency. However, 76\% of all studies evaluate light touch interventions, the long-term impact of which remains unclear. The modal intervention uses mentalizing as a salve for prejudice. Although these studies report optimistic conclusions, we identify troubling indications of publication bias that may exaggerate effects. Furthermore, landmark studies often find limited effects, which suggests the need for further theoretical innovation or synergies with other kinds of psychological or structural interventions. We conclude that much research effort is theoretically and empirically ill-suited to provide actionable, evidence-based recommendations for reducing prejudice.},
	language = {en},
	number = {Volume 72, 2021},
	urldate = {2026-01-23},
	journal = {Annual Review of Psychology},
	publisher = {Annual Reviews},
	author = {Paluck, Elizabeth Levy and Porat, Roni and Clark, Chelsey S. and Green, Donald P.},
	month = jan,
	year = {2021},
	pages = {533--560},
	file = {Full Text:/Users/rima-mariarahal/Zotero/storage/PICW9L5Y/Paluck et al. - 2021 - Prejudice Reduction Progress and Challenges.pdf:application/pdf;Snapshot:/Users/rima-mariarahal/Zotero/storage/IR652TCL/annurev-psych-071620-030619.html:text/html},
}


@article{baker_negro-white_1934,
	title = {Negro-{White} {Adjustment} in {America}},
	volume = {3},
	issn = {00222984},
	url = {https://www.jstor.org/stable/2292313?origin=crossref},
	doi = {10.2307/2292313},
	abstract = {A general study of the techniques for race adjustment which have been discovered and tested by national organizations has not been made. The agencies have been active a sufficient length of time to justify research into their history, philosophy, and techniques. Over a period of years they have developed a number of methods which would be of value to all who wish to contribute toward a solution of the race problem. The object of this study is to factor out these methods from the experience of the interracial agencies and so to analyze them that they may be made adaptable to the needs of those working for race betterment. The interracial organizations are not always conscious of the methods they use in making adjustments. Frequently, the techniques which are obvious are not the ones most powerful in shaping behavior. In such cases one must dig deep to locate the more subtle processes at work on building better attitudes. Types of group pressure and personal influence play on a conflict situation to bring about an adjustment. These methods are not easily recognized by the casual observer. It is the object of this study to seek out these hidden methods, as well as the ones easily observed and},
	number = {2},
	urldate = {2026-01-23},
	journal = {The Journal of Negro Education},
	author = {Baker, Paul E.},
	month = apr,
	year = {1934},
	pages = {194},
}

