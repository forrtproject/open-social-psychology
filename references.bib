	pages = {5424--5433},
	file = {Full Text:C\:\\Users\\Owner\\Zotero\\storage\\2KI7KIXP\\Van Den Akker et al. - 2023 - Preregistration in practice A comparison of preregistered and non-preregistered studies in psycholo.pdf:application/pdf},
}

