	keywords = {Humanities and Social Sciences, multidisciplinary, Science},
	pages = {673--676},
	file = {Full Text PDF:/Users/rima-mariarahal/Zotero/storage/JNFNRJ2A/Kosfeld et al. - 2005 - Oxytocin increases trust in humans.pdf:application/pdf},
}

@article{kwantes_predictors_2025,
