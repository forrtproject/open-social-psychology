	file = {Full Text PDF:/Users/rima-mariarahal/Zotero/storage/S3YBL2SL/Andersen and Bem - 1981 - Sex typing and androgyny in dyadic interaction Individual differences in responsiveness to physical.pdf:application/pdf},
}


@article{palmer_halo_2016,
